// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}


// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum MovementType {
  ENTRADA
  SALIDA
}

enum AlertType {
  STOCK_BAJO
}

enum AlertStatus {
  ACTIVA
  RESUELTA
}

enum OrderStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  RECIBIDA
}

// ─────────────────────────────────────────────
// MODELOS
// ─────────────────────────────────────────────

model Product {
  id           String   @id @default(uuid())
  name         String   @db.VarChar(100)
  sku          String   @unique @db.VarChar(20)
  category     String
  price        Decimal  @db.Decimal(12, 2)
  currentStock Int      @default(0)
  minStock     Int
  supplier     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements StockMovement[]
  alerts    Alert[]
  orders    PurchaseOrder[]

  @@index([category])
  @@index([supplier])
  @@index([currentStock])
  @@map("products")
}

model StockMovement {
  id        String       @id @default(uuid())
  productId String
  type      MovementType
  quantity  Int // > 0 (validado en DTO)
  reason    String
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
  @@map("stock_movements")
}

model Alert {
  id         String      @id @default(uuid())
  productId  String
  type       AlertType   @default(STOCK_BAJO)
  status     AlertStatus @default(ACTIVA)
  createdAt  DateTime    @default(now())
  resolvedAt DateTime? // null mientras esté ACTIVA

  product Product         @relation(fields: [productId], references: [id])
  orders  PurchaseOrder[]

  @@index([productId, status])
  @@map("alerts")
}
model PurchaseOrder {
  id              String      @id @default(uuid())
  productId       String
  alertId         String?
  supplier        String
  quantity        Int
  status          OrderStatus @default(PENDIENTE)
  rejectionReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  product Product @relation(fields: [productId], references: [id])
  alert   Alert?  @relation(fields: [alertId], references: [id])

  @@index([productId])
  @@index([status])
  @@map("purchase_orders")
}
